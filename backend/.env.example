APP_NAME="pizza-backend"
ENV="dev"
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=pizza
POSTGRES_USER=pizza
POSTGRES_PASSWORD=pizza

DATABASE_URL=postgresql+asyncpg://pizza:pizza@127.0.0.1:5432/pizza

JWT_SECRET_KEY="CHANGE_ME_SUPER_SECRET"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=120
